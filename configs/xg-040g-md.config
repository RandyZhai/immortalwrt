# ============================================================
# ImmortalWrt Seed Config for Nokia XG-040G-MD (UBI)
# 平台: Airoha AN7581 / ARM64 Cortex-A53
# ============================================================
# 使用方法:
#   cp configs/xg-040g-md.config .config
#   make defconfig
#   make -j$(nproc) V=s
# ============================================================

# ========== 目标平台 ==========
CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_airoha_an7581_DEVICE_nokia_xg-040g-md-ubi=y
# （设备默认驱动包由 DEVICE_PACKAGES 自动引入，无需手动覆盖）

# ========== 默认设备驱动（已由 DEVICE_PACKAGES 自动引入，此处仅记录）==========
# ✅ kmod-usb3 → kmod-usb-xhci-mtk → kmod-usb-xhci-hcd   (USB 3.0 控制器)
# ✅ kmod-phy-airoha-en8811h + airoha-en8811h-firmware     (2.5G EN8811H PHY)
# ✅ kmod-usb-ledtrig-usbport                              (USB LED 触发)
# ✅ kmod-gpio-button-hotplug + kmod-leds-gpio             (GPIO 按键/LED)
# ✅ kmod-regulator-userspace-consumer                     (USB 电源管理)
# ✅ airoha-en7581-npu-firmware + CONFIG_NET_AIROHA_NPU=y  (NPU 网络加速)
# ✅ kmod-phy-airoha-en8811h                               (EN8811H 2.5G PHY)
# ✅ fitblk                                                 (UBI fit 块设备)

# ========== USB 存储支持 ==========
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_blockd=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y        # UASP (USB 3.0 高速存储协议)
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y               # exFAT 支持
CONFIG_PACKAGE_kmod-fs-ntfs3=y               # NTFS 读写支持 (内核级)
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# ========== USB 网络/串口/其他 ==========
CONFIG_PACKAGE_kmod-usb-net=y                # USB 网卡基础
CONFIG_PACKAGE_kmod-usb-net-rndis=y          # Android USB 共享网络
CONFIG_PACKAGE_kmod-usb-serial=y             # USB 串口 (TTL/CH340/CP210x)
CONFIG_PACKAGE_kmod-usb-serial-ftdi=y        # FTDI USB 串口
CONFIG_PACKAGE_kmod-usb-serial-pl2303=y      # PL2303 USB 串口

# ========== LuCI 配置导航 (Web 管理界面 + 中文) ==========
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y

# ========== LuCI 主题 (Argon) ==========
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
CONFIG_PACKAGE_luci-app-argon-config=y

# ========== iStore 应用商店 ==========
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-lib-taskd=y
CONFIG_PACKAGE_luci-lib-xterm=y
CONFIG_PACKAGE_taskd=y
CONFIG_PACKAGE_quickstart=y
CONFIG_PACKAGE_luci-app-quickstart=y

# ========== ZeroTier 虚拟局域网 ==========
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_zerotier=y

# ========== Turbo ACC 网络加速 (NPU 硬件加速管理面板) ==========
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_shortcut-fe=y
CONFIG_PACKAGE_shortcut-fe-drv=y

# ========== OpenClash 科学上网 ==========
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_dnsmasq-full=y                  # OpenClash 依赖 (替代 dnsmasq)
CONFIG_PACKAGE_coreutils-nohup=y               # 后台运行支持
CONFIG_PACKAGE_ca-certificates=y               # SSL 证书
CONFIG_PACKAGE_ca-bundle=y                     # CA 证书包
CONFIG_PACKAGE_iptables-mod-tproxy=y           # TPROXY 透明代理
CONFIG_PACKAGE_kmod-inet-diag=y                # 网络诊断 (socket 信息)

# ========== Docker 容器 ==========
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_docker-compose=y

# ========== 实用工具 ==========
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-nossl=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_luci-app-commands=y

# ========== 网络工具 ==========
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_ip6tables-mod-nat=y
CONFIG_PACKAGE_resolveip=y

# ========== 不使用 APK，使用 opkg (iStore 兼容) ==========
CONFIG_USE_APK=n
CONFIG_PACKAGE_opkg=y
